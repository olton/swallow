{
  "name": "swallow",
  "version": "1.0.0",
  "description": "Lightweight Agent SDK for local/remote LLM providers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "npm run build && node public/demo-server.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/agent-client.test.ts",
    "test:live": "vitest run tests/ollama.live.test.ts",
    "test:openai": "vitest run tests/openai-compatible-provider.test.ts",
    "test:openai:native": "vitest run tests/openai-provider.test.ts",
    "test:anthropic": "vitest run tests/anthropic-provider.test.ts",
    "test:azure": "vitest run tests/azure-openai-provider.test.ts",
    "test:gemini": "vitest run tests/gemini-provider.test.ts",
    "test:live:openai": "vitest run tests/openai-compatible.live.test.ts",
    "test:live:lmstudio": "vitest run tests/lmstudio.live.ts",
    "test:live:openai:native": "vitest run tests/openai.live.test.ts",
    "test:live:azure": "vitest run tests/azure-openai.live.test.ts",
    "test:live:gemini": "vitest run tests/gemini.live.test.ts",
    "test:live:all": "vitest run tests/ollama.live.test.ts tests/openai-compatible.live.test.ts tests/openai.live.test.ts tests/azure-openai.live.test.ts tests/gemini.live.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
