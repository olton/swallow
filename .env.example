# Swallow SDK environment variables
# Copy this file to .env if you use an env loader in your app/scripts.

# -----------------------------
# Demo server (npm run demo)
# -----------------------------
# Host where the demo server listens
DEMO_HOST=127.0.0.1
# Port where the demo server listens
DEMO_PORT=5177
# Ollama host used by demo server and native Ollama live test
OLLAMA_HOST=http://localhost:11434

# -----------------------------
# Native Ollama live test
# npm run test:live
# -----------------------------
# Optional fixed model for native Ollama live test
# If empty, the first available model is used.
OLLAMA_MODEL=

# -----------------------------
# OpenAI-compatible live test against Ollama
# npm run test:live:openai
# -----------------------------
OLLAMA_OPENAI_HOST=http://localhost:11434/v1
# Optional fixed model; first available model is used when empty
OLLAMA_OPENAI_MODEL=

# -----------------------------
# OpenAI-compatible live test against LM Studio
# npm run test:live:lmstudio
# -----------------------------
LMSTUDIO_OPENAI_HOST=http://localhost:1234/v1
# Optional fixed model; first available model is used when empty
LMSTUDIO_OPENAI_MODEL=

# -----------------------------
# Anthropic provider (application-level usage)
# -----------------------------
# API key for AnthropicProvider
ANTHROPIC_API_KEY=
# Optional base URL override (default: https://api.anthropic.com)
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Optional API version header override (default in provider: 2023-06-01)
ANTHROPIC_VERSION=2023-06-01

# -----------------------------
# OpenAI native provider
# -----------------------------
OPENAI_API_KEY=
# Optional base URL override (default: https://api.openai.com/v1)
OPENAI_BASE_URL=https://api.openai.com/v1
# Optional fixed model for OpenAI live test
OPENAI_MODEL=

# -----------------------------
# Gemini native provider
# -----------------------------
GEMINI_API_KEY=
# Optional base URL override (default: https://generativelanguage.googleapis.com)
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# Optional fixed model for Gemini live test (default in tests: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------
# Azure OpenAI native provider
# -----------------------------
AZURE_OPENAI_API_KEY=
# Example: https://your-resource-name.openai.azure.com
AZURE_OPENAI_BASE_URL=
# Deployment name used as "model" in SDK requests
AZURE_OPENAI_DEPLOYMENT=
# Optional API version (default in provider: 2024-10-21)
AZURE_OPENAI_API_VERSION=2024-10-21

# -----------------------------
# External MCP server (optional)
# -----------------------------
# Example: https://your-mcp-server.example.com/mcp
MCP_SERVER_URL=
# Optional bearer token for MCP server auth
MCP_BEARER_TOKEN=
