# Swallow SDK environment variables
# Copy this file to .env if you use an env loader in your app/scripts.

# -----------------------------
# Demo server (npm run demo)
# -----------------------------
# Host where the demo server listens
DEMO_HOST=127.0.0.1
# Port where the demo server listens
DEMO_PORT=5177
# Ollama host used by demo server and native Ollama live test
OLLAMA_HOST=http://localhost:11434

# -----------------------------
# Native Ollama live test
# npm run test:live
# -----------------------------
# Optional fixed model for native Ollama live test
# If empty, the first available model is used.
OLLAMA_MODEL=

# -----------------------------
# OpenAI-compatible live test against Ollama
# npm run test:live:openai
# -----------------------------
OLLAMA_OPENAI_HOST=http://localhost:11434/v1
# Optional fixed model; first available model is used when empty
OLLAMA_OPENAI_MODEL=

# -----------------------------
# OpenAI-compatible live test against LM Studio
# npm run test:live:lmstudio
# -----------------------------
LMSTUDIO_OPENAI_HOST=http://localhost:1234/v1
# Optional fixed model; first available model is used when empty
LMSTUDIO_OPENAI_MODEL=

# -----------------------------
# Anthropic provider (application-level usage)
# -----------------------------
# API key for AnthropicProvider
ANTHROPIC_API_KEY=
# Optional base URL override (default: https://api.anthropic.com)
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Optional API version header override (default in provider: 2023-06-01)
ANTHROPIC_VERSION=2023-06-01
